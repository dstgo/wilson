    "definitions": {
        "auth.ForgotPasswordOption": {
            "type": "object",
            "properties": {
                "code": {
                    "description": "auth code get from user binding email",
                    "type": "string",
                    "example": "F294484D"
                },
                "password": {
                    "description": "length of the password must be in range [10,30]",
                    "type": "string",
                    "example": "123456789"
                }
            }
        },
        "auth.LoginOption": {
            "type": "object",
            "properties": {
                "password": {
                    "description": "length of the password must be in range [10,30]",
                    "type": "string",
                    "example": "123456789"
                },
                "username": {
                    "description": "length of the username must be in range [6,20], and username must be Alphanumeric",
                    "type": "string",
                    "example": "123456@example.com/username"
                }
            }
        },
        "auth.RegisterOption": {
            "type": "object",
            "properties": {
                "code": {
                    "description": "8-digit auth code get from user binding email, and it must be Alphanumeric",
                    "type": "string",
                    "example": "F294484D"
                },
                "password": {
                    "description": "length of the password must be in range [10,30]",
                    "type": "string",
                    "example": "123456789"
                },
                "username": {
                    "description": "length of the username must be in range [6,20], and username must be Alphanumeric",
                    "type": "string",
                    "example": "123456@example.com/username"
                }
            }
        },
        "user.Info": {
            "type": "object",
            "properties": {
                "createdAt": {
                    "type": "string",
                    "example": "2022-01-01 00:00:00"
                },
                "email": {
                    "type": "string",
                    "example": "jacklove@lol.com"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "username": {
                    "type": "string",
                    "example": "jack"
                },
                "uuid": {
                    "type": "string",
                    "example": "55BBA4ED-18D3-790F-EABF-A5330E527586"
                }
            }
        },
        "user.PageOption": {
            "type": "object",
            "properties": {
                "desc": {
                    "description": "if is reverse order",
                    "type": "boolean",
                    "example": true
                },
                "order": {
                    "description": "specified field",
                    "type": "string",
                    "example": "email"
                },
                "page": {
                    "description": "page",
                    "type": "integer",
                    "example": 1
                },
                "search": {
                    "description": "search text, should be of one username or email",
                    "type": "string",
                    "example": "jacklove"
                },
                "size": {
                    "description": "size of page",
                    "type": "integer",
                    "example": 10
                }
            }
        },
        "user.UpdateInfoOption": {
            "type": "object",
            "properties": {
                "email": {
                    "description": "new email",
                    "type": "string",
                    "example": "jack@google.com"
                },
                "id": {
                    "description": "specified user id",
                    "type": "integer",
                    "example": 1
                },
                "password": {
                    "description": "new password",
                    "type": "string",
                    "example": "123456"
                },
                "username": {
                    "description": "new username",
                    "type": "string",
                    "example": "jack"
                }
            }
        }
    }
